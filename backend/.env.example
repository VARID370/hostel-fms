PORT=5000
MONGO_URI=mongodb://localhost:27017/hostel_fms
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Admin registration code
ADMIN_CODE=OUR_MESS

# Nodemailer - Gmail App Password recommended
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=HostelEats <your_email@gmail.com>

# Meal booking deadlines (minutes before meal time)
BREAKFAST_DEADLINE_MINS=30
LUNCH_DEADLINE_MINS=60
SNACKS_DEADLINE_MINS=30
DINNER_DEADLINE_MINS=60

# Meal times 24hr HH:MM
BREAKFAST_TIME=07:00
LUNCH_TIME=12:00
SNACKS_TIME=16:00
DINNER_TIME=19:00

# Meal prices (INR) for billing
PRICE_BREAKFAST=30
PRICE_LUNCH=60
PRICE_SNACKS=20
PRICE_DINNER=60
